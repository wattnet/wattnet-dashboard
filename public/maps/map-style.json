{
  "version": 8,
  "sources": {
    "world-zones": {
      "type": "geojson",
      "data": "maps/wattnet.geojson"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#143262"
      }
    },
    {
      "id": "world-fill",

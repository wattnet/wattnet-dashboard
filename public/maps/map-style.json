{
  "version": 8,
  "sources": {
    "world-zones": {
      "type": "geojson",
      "data": "maps/wattnet.geojson"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#143262"
      }
    },
    {
      "id": "world-fill",
      "type": "fill",
      "source": "world-zones",
      "paint": {
        "fill-color": "#1a2a45",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "world-line",
      "type": "line",
      "source": "world-zones",
      "paint": {
        "line-color": "#888888",
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 2, 7, 4]
      }
    }
  ]
}
